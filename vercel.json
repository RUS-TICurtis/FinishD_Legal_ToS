{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/functions/v1/store-deletion-request",
      "destination": "/server.js"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
